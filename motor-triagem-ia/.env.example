# Microsserviços: bancos separados
# Se errar "no pg_hba.conf entry", o DBA deve autorizar seu IP no pg_hba.conf do PostgreSQL.
# Para dev sem SSL: postgresql://user:pass@host:5432/db?sslmode=disable
SINAPSE_DB_URL=postgresql://usuario:senha@localhost:5432/sinapse
SEI_AI_DB_URL=postgresql://usuario:senha@localhost:5432/sei_ai

# Groq API (LLM - inferência)
GROQ_API_KEY=gsk_xxx

# Embeddings (API interna)
EMBEDDING_API_URL=http://192.168.10.50:8004/v1/embeddings
GROQ_BASE_URL=https://api.groq.com/openai/v1
